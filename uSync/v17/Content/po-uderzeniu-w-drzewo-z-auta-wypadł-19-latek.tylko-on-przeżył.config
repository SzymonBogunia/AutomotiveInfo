        {
          "alias": "text",
          "culture": null,
          "editorAlias": null,
          "segment": null,
          "value": {
            "blocks": {
              "contentData": [],
              "settingsData": [],
              "expose": [],
              "layout": {}
            },
            "markup": "\u003Cp\u003E\u003Cstrong\u003E19-latek wypad\u0142 z auta, tylko on prze\u017Cy\u0142\u003C/strong\u003E\u003C/p\u003E\u003Cp style=\u0022text-align: left;\u0022\u003EPo uderzeniu w drzewo z samochodu wypad\u0142 19-latek. M\u0119\u017Cczyzna trafi\u0142 do szpitala w Nowym Tomy\u015Blu.\u003C/p\u003E\u003Cp style=\u0022text-align: left;\u0022\u003EW wypadku zgin\u0119li 26-latek i 23-latek.\u0026nbsp;Obaj byli zakleszczeni w poje\u017Adzie.\u003C/p\u003E\u003Cp style=\u0022text-align: left;\u0022\u003ENa miejscu zdarzenia pracowa\u0142y cztery zast\u0119py stra\u017Cy po\u017Carnej, policja i pogotowie ratunkowe.\u003C/p\u003E"
          }
        },
        {
          "alias": "imagePosition",

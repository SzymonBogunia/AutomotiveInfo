@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.FrontPage>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@using Umbraco.Extensions

@{
    Layout = "_Layout.cshtml";
    // Pobranie zdjęcia z Media Pickera 3 bezpieczną metodą
    var heroImageUrl = Model.HeroImage?.Url() ?? "https://images.unsplash.com/photo-1617788138017-80ad40651399?auto=format&fit=crop&w=1920&q=80";
}

<section class="relative bg-slate-950 py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-40 bg-cover bg-center" style="background-image: url('@heroImageUrl');"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-slate-950 via-slate-950/90 to-transparent z-10"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-20">
        <div class="max-w-2xl">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-red-500/10 text-red-400 mb-6 border border-red-500/20 uppercase tracking-wider">
                Pasja i Technologia
            </span>
            <h1 class="text-4xl md:text-6xl font-extrabold text-white tracking-tight leading-none mb-6">
                @Model.HeroTitle
            </h1>
            <p class="text-lg md:text-xl text-slate-300 mb-10 leading-relaxed">
                @Model.HeroLead
            </p>

            @if (Model.HeroCta != null && Model.HeroCta.Any())
            {
                // Pobieramy pierwszy link z kolekcji
                var firstCta = Model.HeroCta.FirstOrDefault();
                if (firstCta != null)
                {
                    <div>
                        <a href="@firstCta.Url" target="@firstCta.Target" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-semibold rounded-lg text-white bg-red-600 hover:bg-red-500 shadow-lg shadow-red-600/30 transition-all hover:-translate-y-0.5">
                            @firstCta.Name
                            <svg class="ml-2 -mr-1 w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    @if (Model.Components != null)
    {
        <div class="space-y-16">
            @Html.GetBlockListHtml(Model.Components)
        </div>
    }
</section>
@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockListItem>
@using Umbraco.Extensions

@{
    // Sprawdzenie czy ukryć komponent
    var hide = Model.Settings?.Value<bool>("hideBlockElement") ?? false;
    if (hide)
    {
        return;
    }

    // 1. Pobranie danych z pól
    var textValue = Model.Content.Value("text")?.ToString();
    var image = Model.Content.Value<IPublishedContent>("image");

    // 2. Pobranie pozycji (np. "Lewo", "Centruj", "Prawo"). Jeśli puste, domyślnie ustawiamy "Lewo"
    var position = Model.Content.Value<string>("imagePosition") ?? "Lewo";

    // 3. Dynamiczne dopasowanie układu Flexbox na podstawie wybranej opcji
    var layoutClass = "md:flex-row"; // Domyślnie zdjęcie po lewej, tekst po prawej

    if (position == "Prawo")
    {
        layoutClass = "md:flex-row-reverse"; // Odwracamy kolejność (zdjęcie po prawej)
    }
    else if (position == "Centruj")
    {
        layoutClass = "flex-col text-center"; // Układ pionowy z wyśrodkowaniem tekstu
    }
}

<div class="flex flex-col @layoutClass gap-8 my-12 items-center">

    @if (image != null)
    {
        // Jeśli wybrano "Centruj", możemy nieco ograniczyć maksymalną szerokość zdjęcia, by ładnie wyglądało w pionie
        var imageSizeClass = position == "Centruj" ? "max-w-2xl w-full" : "w-full md:w-1/2";

        <div class="@imageSizeClass">
            <img src="@image.Url()" alt="Zdjęcie komponentu" class="rounded-2xl w-full h-auto object-cover max-h-[450px] shadow-lg border border-slate-800/60" />
        </div>
    }

    @if (!string.IsNullOrEmpty(textValue))
    {
        var textSizeClass = position == "Centruj" ? "w-full" : "w-full md:w-1/2";

        <div class="@textSizeClass prose prose-invert max-w-none text-white">
            @Html.Raw(textValue)
        </div>
    }
</div>
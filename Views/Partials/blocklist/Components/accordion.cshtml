@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockListItem>
@using Umbraco.Extensions
@using Umbraco.Cms.Core.Strings

@{
    if (Model.Settings?.Value<bool>("hideBlockElement") ?? false) { return; }

    // Pobieramy tytuł całej sekcji akordeonu (np. "Najczęściej zadawane pytania")
    var title = Model.Content.Value<string>("title");

    // Pobieramy wewnętrzną Block Listę z elementami (pytaniami)
    var items = Model.Content.Value<Umbraco.Cms.Core.Models.Blocks.BlockListModel>("items");
}

<div class="my-16 max-w-4xl mx-auto">
    @if (!string.IsNullOrEmpty(title))
    {
        <h2 class="text-2xl md:text-3xl font-extrabold text-white mb-8 tracking-tight text-center md:text-left">
            @title
        </h2>
    }

    @if (items != null && items.Any())
    {
        <div class="space-y-4">
            @foreach (var item in items)
            {
                // Wyciągamy dane z pojedynczego elementu (accordionBlock)
                var heading = item.Content.Value<string>("heading");
                var content = item.Content.Value<IHtmlEncodedString>("content");

                if (!string.IsNullOrEmpty(heading))
                {
                    <details class="group bg-slate-900 border border-slate-800/80 rounded-2xl overflow-hidden [&_summary::-webkit-details-marker]:hidden transition-all duration-300">
                        <summary class="flex items-center justify-between p-5 md:p-6 text-white font-bold cursor-pointer select-none hover:bg-slate-800/30 transition-colors focus:outline-none">
                            <span class="text-base md:text-lg pr-4">@heading</span>
                            <span class="text-red-500 transition-transform duration-300 group-open:rotate-180 shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                </svg>
                            </span>
                        </summary>

                        @if (content != null && !string.IsNullOrEmpty(content.ToString()))
                        {
                            <div class="p-5 md:p-6 border-t border-slate-800/60 text-slate-300 leading-relaxed prose prose-invert prose-sm max-w-none">
                                @content
                            </div>
                        }
                    </details>
                }
            }
        </div>
    }
    else
    {
        @* Zabezpieczenie na wypadek, gdyby edytor dodał pusty kontener *@
        <div class="text-center py-8 bg-slate-900/20 rounded-2xl border border-dashed border-slate-800">
            <p class="text-sm text-slate-500">Ten akordeon nie zawiera jeszcze żadnych pytań.</p>
        </div>
    }
</div>
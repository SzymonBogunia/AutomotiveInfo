@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Umbraco.Cms.Core.Models.Blocks.BlockListItem>
@using Umbraco.Extensions
@using Umbraco.Cms.Core.Strings @* Dodane dla IHtmlEncodedString *@

@{
    if (Model.Settings?.Value<bool>("hideBlockElement") ?? false) { return; }

    // Pobieramy jako bezpieczny IHtmlEncodedString
    var textContent = Model.Content.Value<IHtmlEncodedString>("componentText");
}

@if (textContent != null && !string.IsNullOrEmpty(textContent.ToString()))
{
    <div class="prose prose-invert max-w-none my-8 leading-relaxed [&_p]:mb-6">
        @textContent
    </div>
}
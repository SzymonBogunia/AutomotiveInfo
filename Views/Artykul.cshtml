@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<ContentModels.NewsPage>
@using ContentModels = Umbraco.Cms.Web.Common.PublishedModels;
@using Umbraco.Extensions

@{
    Layout = "_Layout.cshtml";

    var authorNode = Model.Author as ContentModels.Author;

    var tagNode = Model.Tag as ContentModels.Tag;

    var mainImage = Model.MainImage;
}

<article class="container mx-auto px-4 py-12 max-w-4xl">
    <div class="flex flex-wrap items-center gap-4 text-sm text-slate-400 mb-4">
        @if (Model.PublishDate != default)
        {
            <time datetime="@Model.PublishDate.ToString("yyyy-MM-dd")">
                📅 @Model.PublishDate.ToString("dd.MM.yyyy")
            </time>
        }

        @if (authorNode != null)
        {
            <span class="font-medium text-slate-300">✍️ @authorNode.FirstName @authorNode.SecondName</span>
        }

            <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-500/10 text-red-400 border border-red-500/20">
                #@tagNode.TagName

    </div>

    <h1 class="text-3xl md:text-5xl font-extrabold text-white mb-8 leading-tight">
        @(string.IsNullOrEmpty(Model.ArticleTitle) ? Model.Name : Model.ArticleTitle)
    </h1>

    @if (mainImage != null)
    {
        <div class="mb-12 overflow-hidden rounded-3xl border border-slate-800/80 shadow-2xl">
            @* Wywołanie .Url() na silnie typowanym obiekcie mediów *@
            <img src="@mainImage.Url()" alt="Zdjęcie główne artykułu" class="w-full h-auto max-h-[500px] object-cover" />
        </div>
    }

    @if (Model.Components != null && Model.Components.Any())
    {
        <div class="space-y-12 border-t border-slate-800/60 pt-12">
            @Html.GetBlockListHtml(Model.Components)
        </div>
    }
</article>